{
  "schema": 2,
  "permissions": [
    "tools.invoke",
    "storage.read",
    "storage.write"
  ],
  "required_executas": [
    {
      "tool_id": "bundled:summarize",
      "min_version": "0.1.0",
      "version": "latest"
    }
  ],
  "tags": ["notes", "productivity", "llm"],
  "ui": {
    "bundle": {
      "format": "static-spa",
      "entry": "index.html",
      "external_origins": []
    },
    "views": [
      {
        "name": "main",
        "title": "Mini Notes",
        "default": true,
        "entry": "index.html",
        "min_size": { "w": 320, "h": 400 },
        "default_size": { "w": 480, "h": 600 },
        "resizable": true,
        "movable": true,
        "single_instance": true
      }
    ],
    "host_api": {
      "tools": ["mini-notes-summarize"],
      "storage": ["get", "set"]
    },
    "state_merge": "last_writer_wins"
  },
  "dev": {
    "fixtures": ["fixtures/*.jsonl"],
    "seed_storage": {},
    "user_id": 1
  }
}
